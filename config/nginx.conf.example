# Nginx Server Configuration for EcoSphere
# Add this to your nginx configuration block

# Gzip Compression
gzip on;
gzip_vary on;
gzip_min_length 1000;
gzip_types 
  text/plain 
  text/css 
  text/xml 
  text/javascript 
  application/javascript 
  application/xml 
  application/rss+xml 
  application/atom+xml 
  image/svg+xml;

# Gzip compression level (1-9, balance speed vs compression)
gzip_comp_level 6;

# Browser Caching
map $sent_http_content_type $expires {
  default                    off;
  text/html                  1d;
  text/css                   1M;
  application/javascript     1M;
  text/javascript            1M;
  image/jpeg                 1M;
  image/gif                  1M;
  image/png                  1M;
  image/webp                 1M;
  image/svg+xml              1M;
  application/json           1d;
  application/x-web-app-manifest+json  1d;
}

expires $expires;

# Security Headers
add_header X-Frame-Options "SAMEORIGIN" always;
add_header X-XSS-Protection "1; mode=block" always;
add_header X-Content-Type-Options "nosniff" always;
add_header Referrer-Policy "no-referrer-when-downgrade" always;

# Content Security Policy
add_header Content-Security-Policy "default-src 'self'; script-src 'self' 'unsafe-inline'; style-src 'self' 'unsafe-inline'; img-src 'self' data: https:; font-src 'self' data:; connect-src 'self'" always;

# Cache control headers
add_header Cache-Control "public" always;

# Virtual Host Configuration
server {
  listen 80;
  listen [::]:80;
  server_name ecosphere-sustainability.com www.ecosphere-sustainability.com;

  # Redirect HTTP to HTTPS
  return 301 https://$server_name$request_uri;
}

server {
  listen 443 ssl http2;
  listen [::]:443 ssl http2;
  server_name ecosphere-sustainability.com www.ecosphere-sustainability.com;

  # SSL Configuration
  ssl_certificate /path/to/certificate.crt;
  ssl_certificate_key /path/to/private.key;
  ssl_protocols TLSv1.2 TLSv1.3;
  ssl_ciphers HIGH:!aNULL:!MD5;

  # Root directory
  root /var/www/ecosphere;
  index index.html;

  # Default location
  location / {
    try_files $uri $uri/ /index.html;
  }

  # Cache static assets; filenames are not content-hashed
  location ~* \.(css|js|json)$ {
    expires 1M;
    add_header Cache-Control "public" always;
  }

  # Cache images
  location ~* \.(jpg|jpeg|png|gif|webp|svg)$ {
    expires 1M;
    add_header Cache-Control "public" always;
  }

  # Don't cache HTML
  location ~* \.html$ {
    expires 1d;
    add_header Cache-Control "public" always;
  }

  # Service Worker - don't cache
  location = /service-worker.js {
    expires 0;
    add_header Cache-Control "public, must-revalidate" always;
  }

  # Manifest - short cache
  location = /manifest.json {
    expires 1d;
    add_header Cache-Control "public" always;
  }

  # Disable access to hidden files
  location ~ /\. {
    deny all;
  }
}

